# edu_rag 云服务器环境配置模板（P0-DR7 — 阿里云版）
# 
# 使用方式：复制为 .env.cloud 并填写实际值
#   cp docker/.env.cloud.example .env.cloud
#   vi .env.cloud
#
# 安全注意：
#   1. 不要将填好的 .env.cloud 提交到 git
#   2. 所有密码使用强密码（至少 16 字符，含大小写+数字+特殊字符）
#   3. 阿里云 AccessKey 使用 RAM 子账号，仅授予必要权限
#   4. .aliyun_env 文件权限设为 600 (chmod 600 .aliyun_env)

# ─── MySQL ───
MYSQL_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# ─── Redis ───
REDIS_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# ─── LLM (DeepSeek API) ───
OPENAI_API_KEY=sk-your-deepseek-api-key
OPENAI_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ─── 应用 ───
APP_API_KEY=
APP_RATE_LIMIT_ENABLED=true

# ─── 本地连接信息 ───
# 本地服务器公网 IP（成都联通，动态IP，如变化需更新）
LOCAL_PUBLIC_IP=101.204.208.80

# ─── frp 内网穿透 ───
# frp 认证 token（客户端和服务端必须一致，至少 32 字符）
FRP_TOKEN=CHANGE_ME_TO_STRONG_TOKEN_32_CHARS_MIN
# frp 仪表盘密码
FRP_DASHBOARD_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
# frp 仪表盘用户名
FRP_DASHBOARD_USER=admin

# ─── Nginx ───
# 本地服务的公网 IP（Nginx upstream 指向此 IP）
NGINX_LOCAL_HOST=101.204.208.80

# ─── 告警 ───
# 飞书机器人 webhook URL（推荐，支持富文本卡片）
# 获取方式：飞书群 → 设置 → 群机器人 → 添加自定义机器人
ALERT_WEBHOOK_URL=

# 钉钉机器人 webhook URL（备选）
# 获取方式：钉钉群 → 群设置 → 智能群助手 → 添加机器人
# ALERT_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx

# ─── 备份 ───
BACKUP_RETAIN_DAYS=7

# ═══ 阿里云专属配置（填入 .aliyun_env 文件）═══
# 以下配置通过 .aliyun_env 文件加载（不放在 .env.cloud 中）
# 
# # 阿里云 RAM AccessKey（DNS/OSS/云监控/快照）
# ALIYUN_ACCESS_KEY_ID=LTAI5tXXXXXXX
# ALIYUN_ACCESS_KEY_SECRET=XXXXXXXXXXXXX
# ALIYUN_REGION=cn-hangzhou
# 
# # OSS 对象存储（备份异地存储）
# ALIYUN_OSS_BUCKET=edu-rag-backup
# ALIYUN_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# 
# # 云解析 DNS（流量切换，可选）
# ALIYUN_DNS_DOMAIN=edu.example.com
# ALIYUN_DNS_RECORD_ID=1234567
# 
# # 公网 IP（DNS 切换用）
# LOCAL_PUBLIC_IP=your.local.public.ip
# CLOUD_PUBLIC_IP=your.cloud.public.ip
