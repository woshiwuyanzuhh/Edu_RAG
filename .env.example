# ============================================================
# edu_rag v2.0 环境变量模板
# 复制此文件为 .env 并填入实际配置
# 使用 Pydantic Settings 嵌套模型，分隔符为 __ (双下划线)
# ============================================================

# ── LLM 配置 ──
LLM__API_KEY=sk-your-key-here
LLM__BASE_URL=https://api.deepseek.com/v1
LLM__MODEL=deepseek-chat
LLM__MAX_RETRIES=3
LLM__RETRY_BACKOFF=2.0

# ── Embedding 配置 ──
# provider: "api" (Ollama/OpenAI) 或 "local" (sentence-transformers)
EMBEDDING__PROVIDER=api
EMBEDDING__MODEL=bge-m3
EMBEDDING__API_BASE_URL=http://localhost:11434/v1
EMBEDDING__API_KEY=ollama
# 本地模式模型（仅 EMBEDDING_PROVIDER=local 时生效）
EMBEDDING__LOCAL_MODEL=shibing624/text2vec-base-chinese

# ── 向量数据库配置 ──
# provider: "chroma" (本地) 或 "milvus" (远程)
VECTOR_STORE__PROVIDER=chroma
# ChromaDB 路径（留空使用默认值 data/chroma）
VECTOR_STORE__CHROMA_PATH=
# Milvus 连接（仅 provider=milvus 时生效）
VECTOR_STORE__MILVUS_HOST=localhost
VECTOR_STORE__MILVUS_PORT=19530

# ── MySQL 配置 ──
MYSQL__HOST=localhost
MYSQL__PORT=3306
MYSQL__USER=root
MYSQL__PASSWORD=your-secure-password
MYSQL__DATABASE=edu_rag
MYSQL__POOL_SIZE=10
MYSQL__POOL_RECYCLE=3600

# ── Redis 配置 ──
REDIS__HOST=localhost
REDIS__PORT=6379
REDIS__DB=0
REDIS__PASSWORD=
REDIS__DEFAULT_TTL=3600

# ── 检索参数配置 ──
RETRIEVAL__MIN_SCORE=0.3
RETRIEVAL__FUSION_ALPHA=0.7
RETRIEVAL__MAX_CHUNKS=10
RETRIEVAL__RECALL_MULTIPLIER=10

# ── Generation Feature Flags ──
GENERATION__ENABLE_LOST_MIDDLE=true
GENERATION__ENABLE_RELEVANCE_FILTER=false
GENERATION__ENABLE_COMPRESSION=false
GENERATION__ENABLE_HYDE=false
GENERATION__ENABLE_REFUSE=true

# ── Ingestion 配置 ──
INGRESS_CFG__CHUNK_SIZE=800
INGRESS_CFG__CHUNK_OVERLAP=100

# ── 应用配置 ──
APP__HOST=0.0.0.0
APP__PORT=8000
# 上传文件目录（留空使用默认值 data/）
APP__UPLOAD_DIR=
APP__MAX_UPLOAD_SIZE_MB=50
APP__DEBUG=false
# API 鉴权密钥（为空则跳过鉴权，生产环境请务必设置 ≥32 字符）
APP__API_KEY=
